# Sao chép file này thành .env trong thư mục frontend/ và điền các giá trị.
# Lấy giá trị từ CDK output sau khi chạy: cdk deploy
# KHÔNG commit file .env vào git.

# CDK output: UserPoolId
VITE_COGNITO_USER_POOL_ID=ap-southeast-1_XXXXXXXXX

# CDK output: UserPoolClientId
VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# CDK output: ApiUrl (bỏ dấu / cuối nếu có)
VITE_API_BASE_URL=https://xxxxxxxxxx.execute-api.ap-southeast-1.amazonaws.com/dev

# Tên môi trường (dev | staging | production)
VITE_ENVIRONMENT_NAME=dev
